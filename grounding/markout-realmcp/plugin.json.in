{
  "name": "markout-realmcp",
  "version": "0.1.0",
  "description": "External-validity unit: registers the REAL NuGet.Mcp.Server (get_package_context) on the Markout task so we can compare its delivery (README vs AGENTS.md) against a raw package-on-disk baseline and our controlled MCP.",
  "skills": ["./"],
  "mcpServers": {
    "nuget": {
      "command": "dnx",
      "args": ["NuGet.Mcp.Server", "--yes"]
    }
  }
}
